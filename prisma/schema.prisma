// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider     = "mysql"
  relationMode = "prisma"
}

model ShoppingList {
  id             Int    @id @default(autoincrement())
  refrigeratorId Int    @map("refrigerator_id")
  productName    String @map("product_name")
  quantity       Float

  // 💡 새롭게 추가한 부분: 수량 단위 (예: "개", "g", "팩") / 안 적을 수도 있으니 String? 로 설정
  unit String?

  isChecked Boolean @default(false) @map("is_checked")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // (참고) 만약 Refrigerator(냉장고) 모델이 이미 있다면 아래처럼 관계를 맺어줄 수 있습니다.
  // refrigerator   Refrigerator @relation(fields: [refrigeratorId], references: [id])

  // 🚨 새롭게 추가한 부분: relationMode="prisma" 환경에서 경고 안 뜨게 해주고 검색 속도 올려주는 인덱스
  @@index([refrigeratorId])
  @@map("shopping_lists") // 데이터베이스에 만들어질 실제 테이블 이름
}
