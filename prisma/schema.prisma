generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider     = "mysql"
  relationMode = "prisma"
}

enum StorageType {
  REFRIGERATED
  FROZEN
  ROOM_TEMP
}

enum ProductStatus {
  STORED
  CONSUMED
  DISCARDED
}

enum Unit {
  EA
  G
  KG
  ML
  L
}

enum AddMethod {
  MANUAL
  RECEIPT
}

enum RoleType {
  USER
  ADMIN
}

model User {
  id        Int       @id @default(autoincrement())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  nickname String @unique
  password String
  email    String @unique

  birthdate DateTime?
  role      RoleType  @default(USER)
}

model Notice {
  id        Int       @id @default(autoincrement())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  title     String
  content   String
}

model Fridge {
  id        Int       @id @default(autoincrement())
  name      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  products Product[]
}

model Category {
  id        Int     @id @default(autoincrement())
  name      String
  isDefault Boolean @default(false) @map("is_default")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  products Product[]

  @@map("categories")
}

model Product {
  id             Int           @id @default(autoincrement())
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  name           String
  memo           String?
  addMethod      AddMethod     @default(MANUAL) @map("add_method")
  storageType    StorageType   @map("storage_type")
  quantity       Float
  unit           Unit
  expirationDate DateTime      @map("expiration_date")
  status         ProductStatus @default(STORED)

  fridgeId   Int      @map("refrigerator_id")
  fridge     fridge   @relation(fields: [fridgeId], references: [id])
  categoryId Int      @map("category_id")
  category   Category @relation(fields: [categoryId], references: [id])

  @@index([fridgeId])
  @@index([categoryId])
  @@map("products")
}
